# ─────────────────────────────────────────────
#  SSBPulse — Environment Variables
#  Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────

# NewsData.io (free: 200 req/day)
# Register at: https://newsdata.io/register
NEWSDATA_API_KEY=your_newsdata_key_here

# GNews.io (free: 100 req/day)
# Register at: https://gnews.io/register
GNEWS_API_KEY=your_gnews_key_here

# Groq (free — AI chat feature)
# Register at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
